{
    "name": "vue-samba/ad-management",
    "description": "基于 Samba 的 AD 域管理系统",
    "type": "project",
    "keywords": ["ad", "ldap", "samba", "user-management"],
    "license": "MIT",
    "require": {
        "php": ">=7.4.0",
        "ext-pdo": "*",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "phpmd/phpmd": "^2.12",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html tests/coverage/html",
        "test:unit": "phpunit --testsuite Unit",
        "test:feature": "phpunit --testsuite Feature",
        "test:integration": "phpunit --testsuite Integration",
        "lint": "phpcs --standard=PSR12 app/ include/",
        "md": "phpmd app/,include/ text codesize,controversial,design,naming,unusedcode"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
